# ------------------------ loader wrappers + self-test --------------------
# These are only emitted in function/custom mode. In argparse-cli / hydra
# wrapper modes the host script owns its own dataloader lifecycle, so there
# is nothing to re-export here.


def build_train_loader(*args, **kwargs):
    return _project_build_train_loader(*args, **kwargs)


def build_val_loader(*args, **kwargs):
    return _project_build_val_loader(*args, **kwargs)


def _self_test() -> None:
    """One-batch smoke test; cache a signature and enforce on subsequent imports."""
    expr_dir = Path(__file__).resolve().parent
    contract_path = expr_dir / "batch_contract.json"
    try:
        loader = _project_build_train_loader()
        it = iter(loader)
        batch = next(it)
    except StopIteration:
        raise RuntimeError("prepare.py self-test: train loader is empty")
    except Exception as e:  # includes dataset path errors
        raise RuntimeError(f"prepare.py self-test: loader construction failed: {e}") from e

    signature = _batch_signature(batch)
    if contract_path.is_file():
        try:
            cached = json.loads(contract_path.read_text(encoding="utf-8"))
        except (OSError, json.JSONDecodeError):
            cached = None
        if cached is not None and cached != signature:
            # Non-fatal: warn on stderr; batch contract mismatch likely means
            # the project's loader shape changed. Operator should rerun setup.
            print(
                f"[prepare.py] WARN: batch contract mismatch. cached={cached!r} "
                f"current={signature!r}",
                file=sys.stderr,
            )
    else:
        try:
            contract_path.write_text(json.dumps(signature, indent=2), encoding="utf-8")
        except OSError:
            pass


def _batch_signature(batch: Any) -> dict[str, Any]:
    """Return a dict-of-{key: {dtype, shape}} signature for a batch."""
    sig: dict[str, Any] = {}
    if isinstance(batch, dict):
        items = batch.items()
    elif isinstance(batch, (tuple, list)):
        items = [(f"[{i}]", v) for i, v in enumerate(batch)]
    else:
        return {"kind": type(batch).__name__}
    for k, v in items:
        entry: dict[str, Any] = {"type": type(v).__name__}
        shape = getattr(v, "shape", None)
        if shape is not None:
            entry["shape"] = list(shape)
        dtype = getattr(v, "dtype", None)
        if dtype is not None:
            entry["dtype"] = str(dtype)
        sig[str(k)] = entry
    return sig


# Run the self-test at import time so any contract violation surfaces before
# `ar run` spawns a subprocess. Set AR_SKIP_SELF_TEST=1 in the environment to
# bypass — useful when the project's dataloader is expensive to instantiate
# (e.g. downloads / decodes / joins shards on first call) and the batch
# contract has already been cached in batch_contract.json.
import os  # noqa: E402

if os.environ.get("AR_SKIP_SELF_TEST") != "1":
    _self_test()
{% endif %}
