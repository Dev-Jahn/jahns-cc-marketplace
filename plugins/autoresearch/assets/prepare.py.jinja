def _get_nested(obj: Any, dotted: str) -> Any:
    """Resolve a dotted key with slash-or-dot separators against a nested dict."""
    if obj is None:
        return None
    if isinstance(obj, dict) and dotted in obj and not isinstance(obj.get(dotted), dict):
        return obj[dotted]
    # try dotted splits
    for sep in ("/", "."):
        parts = dotted.split(sep)
        cur: Any = obj
        ok = True
        for p in parts:
            if isinstance(cur, dict) and p in cur:
                cur = cur[p]
            else:
                ok = False
                break
        if ok:
            return cur
    return None


_LOG_LINE_RE = re.compile(
    r"^\s*([A-Za-z0-9_./-]+)\s*=\s*([-+]?(?:\d+\.?\d*|\.\d+)(?:[eE][-+]?\d+)?)\s*$",
    re.MULTILINE,
)


def extract_metrics_from_log(log_text: str) -> dict[str, float]:
    """Scan `run.log` for `^key=<number>$` lines. Last-seen per key wins.

    Always present regardless of metric_backend — it's the universal fallback
    `ar run` uses when the primary backend yields no metrics (e.g. the host
    crashed before flushing wandb summary / writing tb events).
    """
    wanted = {primary_spec["name"], *aux_keys, *(c["name"] for c in hard_constraints)}
    found: dict[str, float] = {}
    for m in _LOG_LINE_RE.finditer(log_text):
        k, v = m.group(1), m.group(2)
        if k in wanted:
            try:
                found[k] = float(v)
            except ValueError:
                continue
    return found


{% if metric_backend == "wandb" %}
def extract_metrics(wandb_summary: dict) -> dict[str, float]:
    """Pull primary + auxiliary metrics out of wandb-summary.json."""
    out: dict[str, float] = {}
    wanted = [primary_spec["name"], *aux_keys, *(c["name"] for c in hard_constraints)]
    for key in wanted:
        val = _get_nested(wandb_summary, key)
        if val is None:
            continue
        try:
            out[key] = float(val)
        except (TypeError, ValueError):
            continue
    return out
{% elif metric_backend == "tensorboard" %}
def extract_metrics(tb_scalars: dict) -> dict[str, float]:
    """Pull primary + auxiliary metrics out of a tensorboard scalar dict.

    `tb_scalars` is a flat `{tag: last_value}` dict built by `ar` via tbparse
    (preferred) or `EventAccumulator` (fallback). Tensorboard tag names are
    usually slash-separated (e.g. `val/loss`), so we reuse the same nested /
    dotted resolver as the wandb path.
    """
    out: dict[str, float] = {}
    wanted = [primary_spec["name"], *aux_keys, *(c["name"] for c in hard_constraints)]
    for key in wanted:
        # Tag may be present as-is OR under slash/dot splits.
        val = tb_scalars.get(key)
        if val is None:
            val = _get_nested(tb_scalars, key)
        if val is None:
            continue
        try:
            out[key] = float(val)
        except (TypeError, ValueError):
            continue
    return out
