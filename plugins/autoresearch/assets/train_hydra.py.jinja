"""train.py — HYDRA WRAPPER MODE for `{{ expr_slug }}` (entry_pattern=hydra).

This is the ONLY file the agent edits. It is a thin wrapper around the host
project's Hydra-powered training entrypoint (a module whose `main` function is
decorated with `@hydra.main(config_path=..., config_name=...)`). The wrapper:

  1. Loads the agent's `CLI_OVERRIDES` dict below. Keys are Hydra-style dotted
     config paths (e.g. `trainer.max_epochs`, `model.learning_rate`, or with
     a leading `+` to add a new key that isn't in the YAML config, or `~` to
     delete one).
  2. Optionally resolves a parent checkpoint via `prepare.resume_ckpt_path()`
     and injects the resume flag / `AR_RESUME_CKPT` env var. In Hydra the
     resume flag is typically something like `trainer.resume_from_checkpoint`
     and is added to the overrides dict verbatim.
  3. Rebuilds `sys.argv` from `CLI_OVERRIDES` using Hydra override syntax
     (no `--` prefix; `key=value` tokens) and invokes
     `importlib.import_module("{{ entry_main_module }}").main()`. Hydra's
     decorator reads `sys.argv[1:]` to build the config.
  4. After the host script returns, the frozen AR-SAVE block writes
     `wandb_pointer.json` and copies / links the host's saved checkpoint
     into `$AR_RUN_DIR/state.pt`.

### CLI_OVERRIDES syntax (Hydra)

Unlike argparse-cli wrapper mode, the renderer emits Hydra-style tokens:

  - `{"foo.bar": "baz"}`          -> `foo.bar=baz`         (override existing)
  - `{"trainer.max_epochs": 10}`  -> `trainer.max_epochs=10`
  - `{"trainer.gpus": [0, 1]}`    -> `trainer.gpus=[0,1]`  (Hydra list syntax)
  - `{"model.dropout": None}`     -> `model.dropout=null`  (explicit null)
  - `{"+new.key": "val"}`         -> `+new.key=val`        (add — key prefix)
  - `{"~obsolete.key": None}`     -> `~obsolete.key`       (delete — key prefix)

The `+` / `~` prefixes on the KEY are preserved verbatim in the output token
(no leading `--`). Values that are dicts are rendered as Hydra/OmegaConf
mapping literals via `json.dumps`. Booleans become `true`/`false`.

### Rank safety note

Same as argparse-cli mode: `ar` launches this wrapper via the runner spec
(typically `accelerate launch ...` or plain `python`), so this file may be
executed on every rank. Rank-safe behavior is the host script's responsibility.

Mutation scope (advisory; do not write outside this file):
{% for item in mutation_scope %}
  - {{ item }}
{% endfor %}

The frozen AR-RESUME and AR-SAVE blocks are managed by `ar`. Everything between
them — including `RUN_NOTE`, `CLI_OVERRIDES`, and the monkey-patch sandbox — is
agent-editable per run.
"""

from __future__ import annotations

import json
import os
import runpy
import shutil
import signal  # noqa: F401 — available for monkey-patches that install SIGTERM handlers
import sys
import traceback
from pathlib import Path

# ----------------------------------------------------------------------
# Exported env globals — `ar run` sets AR_RUN_ID / AR_EXPR_DIR; we derive
# AR_RUN_DIR and re-export it so the host training script can opt-in to
# saving its checkpoint there (rather than into its own output_dir).
# ----------------------------------------------------------------------

AR_RUN_ID = os.environ.get("AR_RUN_ID", "r0000")
AR_EXPR_DIR = Path(os.environ.get("AR_EXPR_DIR", str(Path(__file__).resolve().parent)))
AR_RUN_DIR = AR_EXPR_DIR / "runs" / AR_RUN_ID
AR_RUN_DIR.mkdir(parents=True, exist_ok=True)
os.environ["AR_RUN_DIR"] = str(AR_RUN_DIR)

# ======================================================================
# PARAMETER BLOCK — edit freely per run.
# ======================================================================

RUN_NOTE = ""  # one-line rationale; surfaced in results.tsv

# CLI_OVERRIDES is the dict of Hydra overrides passed to the host entrypoint.
# Keys are Hydra dotted paths (no `--` prefix). Values may be:
#   - str / int / float          -> rendered as `key=value`
#   - bool                       -> rendered as `key=true` / `key=false`
#   - None                       -> rendered as `key=null` (Hydra convention)
#   - list / tuple               -> rendered as `key=[v1,v2,...]` (Hydra list)
#   - dict                       -> rendered as `key=<json-obj>` (OmegaConf mapping)
#
# Raw-prefix keys: `+foo.bar` adds a key that isn't in the YAML config;
# `~foo.bar` deletes a key (value is ignored for `~`).
#
# The initial dict below was captured from the project during /autoresearch:setup.
# Edit freely per iteration; the AR-RESUME block may append one entry (the
# resume-flag injection) after this dict is defined.
CLI_OVERRIDES = {{ cli_args_json | safe }}

# ======================================================================
# MONKEY-PATCH SANDBOX — apply targeted overrides to host-project modules.
# The subprocess is fresh each run (spawned via `uv run`), so patches can
# never leak into `ar`'s own bookkeeping. Import the host module FIRST, then
# patch, then fall through to the invocation below.
#
# Example:
#   from {{ entry_main_module.rsplit('.', 1)[0] if entry_main_module and '.' in entry_main_module else 'host_project.module' }} import SomeClass
#   original_forward = SomeClass.forward
#   def patched_forward(self, x): ...
#   SomeClass.forward = patched_forward
# ======================================================================

# (agent-editable patches go here)

# ======================================================================
# === AR-RESUME (do not edit; ar manages this) =========================
# Resumes from a parent ckpt if program.md declares parent_ckpt AND the
# host entrypoint accepts a resume flag (recorded as resume_flag_name at
# setup time). We also export AR_RESUME_CKPT so host scripts that don't
# take a CLI flag can opt-in by reading the env var directly.
import prepare  # noqa: E402

_AR_RESUME_PATH = prepare.resume_ckpt_path()
if _AR_RESUME_PATH is not None and _AR_RESUME_PATH.is_file():
    os.environ["AR_RESUME_CKPT"] = str(_AR_RESUME_PATH)
    {% if resume_flag_name %}
    # Resume flag was declared during setup — inject it into CLI_OVERRIDES
    # unless the agent has already set it explicitly above (explicit override
    # wins, so the agent can point at a different ckpt if desired). In Hydra
    # mode the flag is a dotted config path, not a `--flag`; typical examples:
    # `trainer.resume_from_checkpoint`, `ckpt_path`.
    if "{{ resume_flag_name }}" not in CLI_OVERRIDES:
        CLI_OVERRIDES["{{ resume_flag_name }}"] = str(_AR_RESUME_PATH)
    {% else %}
    # No resume flag declared during setup. Host script must consume
    # AR_RESUME_CKPT from the environment if it wants to resume; otherwise
    # the parent ckpt is ignored and training starts from scratch.
    pass
    {% endif %}
    print(f"[AR-RESUME] parent ckpt available at {_AR_RESUME_PATH}", file=sys.stderr)
else:
    # No parent ckpt — normal cold start.
    os.environ.pop("AR_RESUME_CKPT", None)
# === END AR-RESUME ====================================================
# ======================================================================

# ======================================================================
# BODY — rebuild sys.argv from CLI_OVERRIDES (Hydra syntax) and invoke the
# host entrypoint. Do not edit unless you know what you're doing — the CLI
# arg serialization below is the contract between the agent and Hydra.
# ======================================================================


def _render_hydra_value(value) -> str:
    """Serialize a Python value into a Hydra CLI token fragment (RHS of =)."""
    if value is None:
        # Hydra's `null` literal — drops the key's value (but the key still
        # appears in the final config). For full deletion, use a `~key` prefix.
        return "null"
    if isinstance(value, bool):
        return "true" if value else "false"
    if isinstance(value, (int, float)):
        return str(value)
    if isinstance(value, (list, tuple)):
        # Hydra list syntax: [v1,v2,v3]. Use json.dumps on each element to
        # get quoted strings where needed, then strip the outer brackets and
        # whitespace so we match Hydra's terse format.
        inner = ",".join(_render_hydra_value(v) for v in value)
        return f"[{inner}]"
    if isinstance(value, dict):
        # Hydra/OmegaConf mapping literal. json.dumps is already Hydra-compatible
        # for the common cases (double-quoted keys + scalar values).
        return json.dumps(value, separators=(",", ":"))
    # string / everything else
    return str(value)


def _render_hydra_argv(overrides: dict) -> list[str]:
    """Serialize CLI_OVERRIDES into a Hydra argv list (no `--` prefixes).

    Key prefixes are preserved verbatim:
      - `foo.bar`  -> override (must exist in the YAML config)
      - `+foo.bar` -> add (key doesn't need to exist)
      - `~foo.bar` -> delete (value is ignored)
    """
    argv: list[str] = []
    for key, value in overrides.items():
        key = str(key)
        if key.startswith("~"):
            # Deletion — Hydra ignores RHS entirely.
            argv.append(key)
            continue
        rendered_value = _render_hydra_value(value)
        argv.append(f"{key}={rendered_value}")
    return argv


_ENTRY_MAIN_MODULE = {{ entry_main_module | tojson }}
if not _ENTRY_MAIN_MODULE:
    raise RuntimeError(
        "train_hydra.py was rendered without entry_main_module; "
        "re-run /autoresearch:setup with --entry-main-module set."
    )

_argv = _render_hydra_argv(CLI_OVERRIDES)
# Hydra's @hydra.main reads sys.argv[1:]; sys.argv[0] mirrors `python -m <module>`.
sys.argv = [_ENTRY_MAIN_MODULE, *_argv]

# Invocation strategy — import the module and call `main()` directly (the
# function wrapped by @hydra.main). This preserves the module's own __name__
# and lets Hydra pick up the decorator's config_path / config_name as declared.
# If no `main` attribute is defined we fall back to runpy (matches
# `python -m <module>` semantics).
import importlib  # noqa: E402

_host_exit_code = 0
try:
    _mod = importlib.import_module(_ENTRY_MAIN_MODULE)
    _main_fn = getattr(_mod, "main", None)
    if callable(_main_fn):
        print(f"[AR-WRAPPER] calling {_ENTRY_MAIN_MODULE}.main() hydra-argv={_argv}", file=sys.stderr)
        _main_fn()
    else:
        print(f"[AR-WRAPPER] runpy {_ENTRY_MAIN_MODULE} hydra-argv={_argv}", file=sys.stderr)
        runpy.run_module(_ENTRY_MAIN_MODULE, run_name="__main__")
except SystemExit as _se:
    _code = _se.code
    if _code is None or _code == 0:
        _host_exit_code = 0
    elif isinstance(_code, int):
        _host_exit_code = _code
    else:
        _host_exit_code = 1
    if _host_exit_code != 0:
        print(
            f"[AR-WRAPPER] host {_ENTRY_MAIN_MODULE} exited with code={_host_exit_code}",
            file=sys.stderr,
        )

# ======================================================================
# === AR-SAVE (do not edit; ar manages this) ===========================
# Writes wandb_pointer.json first (best-effort; only if wandb is bound),
# then discovers the host's saved checkpoint. Priority order:
#   (0) --checkpoint-glob (Lightning / plain-torch / custom layouts)
#   (a) $AR_RUN_DIR/state.pt          (cooperative host save)
#   (b) $AR_RUN_DIR/state/            (accelerator.save_state dir)
#   (c) CLI_OVERRIDES value for the host's "output_dir" key / checkpoint-*
# ======================================================================

try:
    # (1) wandb pointer binding — best effort, skip silently if wandb isn't used.
    try:
        import wandb  # user venv dep

        _run = getattr(wandb, "run", None)
        if _run is not None:
            _pointer = {
                "wandb_run_id": _run.id,
                "wandb_run_dir": str(Path(_run.dir).parent),
            }
            _pointer_path = AR_RUN_DIR / "wandb_pointer.json"
            with open(_pointer_path, "w", encoding="utf-8") as _f:
                json.dump(_pointer, _f, indent=2)
    except ImportError:
        pass
    except Exception as _e:
        print(f"[AR-SAVE] wandb pointer write failed: {_e}", file=sys.stderr)

    # (2) Checkpoint discovery.
    _target = AR_RUN_DIR / "state.pt"
    _found_from: "str | None" = None

    def _ar_save_copy_into_state_pt(src: Path) -> None:
        """Copy a file (or a directory, tarring it implicitly) to state.pt."""
        if src.is_file():
            shutil.copyfile(src, _target)
        elif src.is_dir():
            import tarfile

            with tarfile.open(_target, "w") as _tf:
                _tf.add(str(src), arcname=src.name)
        else:
            raise FileNotFoundError(f"not a file or directory: {src}")

    {% if checkpoint_glob %}
    # Candidate (0): --checkpoint-glob, evaluated from the project root
    # (os.getcwd() at subprocess launch). Newest-mtime wins. Priority-0.
    _CKPT_GLOB = {{ checkpoint_glob | tojson }}
    _project_root = Path.cwd()
    _glob_matches = sorted(
        (p for p in _project_root.glob(_CKPT_GLOB) if p.exists()),
        key=lambda p: p.stat().st_mtime,
        reverse=True,
    )
    if _glob_matches:
        _latest = _glob_matches[0]
        try:
            _ar_save_copy_into_state_pt(_latest)
            _found_from = f"checkpoint-glob:{_latest.relative_to(_project_root) if _latest.is_relative_to(_project_root) else _latest}"
        except Exception as _e:
            print(f"[AR-SAVE] failed to pack {_latest}: {_e}", file=sys.stderr)

    {% endif %}
    # Candidate (a): host cooperatively saved to $AR_RUN_DIR/state.pt directly.
    _cand_a = AR_RUN_DIR / "state.pt"
    if _found_from is None and _cand_a.is_file() and _cand_a.stat().st_size > 0:
        _found_from = "host-saved-to-state.pt"
    elif _found_from is None:
        # Candidate (b): accelerator.save_state($AR_RUN_DIR/state).
        _cand_b = AR_RUN_DIR / "state"
        if _cand_b.is_dir() and any(_cand_b.iterdir()):
            try:
                _ar_save_copy_into_state_pt(_cand_b)
                _found_from = "accelerate-save-state-dir"
            except Exception as _e:
                print(f"[AR-SAVE] failed to pack {_cand_b}: {_e}", file=sys.stderr)

        # Candidate (c): host wrote to its own output_dir. For Hydra projects,
        # output_dir often lives at `hydra.run.dir` (default cwd) or
        # `paths.output_dir` — we look at a few conventional override keys.
        if _found_from is None:
            _output_dir_str = None
            for _candidate_key in ("output_dir", "hydra.run.dir", "paths.output_dir", "trainer.default_root_dir"):
                _v = CLI_OVERRIDES.get(_candidate_key)
                if _v:
                    _output_dir_str = _v
                    break
            if _output_dir_str:
                _output_dir = Path(str(_output_dir_str)).expanduser()
                if _output_dir.is_dir():
                    _ckpt_candidates = sorted(
                        (p for p in _output_dir.iterdir() if p.is_dir() and p.name.startswith("checkpoint-")),
                        key=lambda p: p.stat().st_mtime,
                        reverse=True,
                    )
                    if _ckpt_candidates:
                        _latest = _ckpt_candidates[0]
                        try:
                            _ar_save_copy_into_state_pt(_latest)
                            _found_from = f"output_dir/{_latest.name}"
                        except Exception as _e:
                            print(
                                f"[AR-SAVE] failed to pack {_latest}: {_e}",
                                file=sys.stderr,
                            )

    if _found_from is None:
        _target.write_bytes(b"")
        _msg = (
            "No checkpoint discovered in any of:\n"
            {% if checkpoint_glob %}
            "  (0) --checkpoint-glob " + repr(_CKPT_GLOB) + " (priority-0; no match)\n"
            {% endif %}
            f"  (a) {AR_RUN_DIR / 'state.pt'} (cooperative host save)\n"
            f"  (b) {AR_RUN_DIR / 'state'}/ (accelerator.save_state dir)\n"
            "  (c) CLI_OVERRIDES output_dir / hydra.run.dir / paths.output_dir -> checkpoint-*\n"
            "Host script must save to one of these locations for `ar` to advance.\n"
        )
        (AR_RUN_DIR / ".ar-save-failed").write_text(_msg, encoding="utf-8")
        print(f"[AR-SAVE] no checkpoint discovered; wrote .ar-save-failed", file=sys.stderr)
    else:
        print(f"[AR-SAVE] state.pt sourced from: {_found_from}", file=sys.stderr)
except Exception as _outer_e:
    try:
        (AR_RUN_DIR / ".ar-save-failed").write_text(
            f"AR-SAVE outer exception: {_outer_e}\n{traceback.format_exc()}",
            encoding="utf-8",
        )
    except Exception:
        pass
# === END AR-SAVE ======================================================
# ======================================================================

if _host_exit_code != 0:
    sys.exit(_host_exit_code)
