# `ar run` exports these two for downstream introspection.
AR_RUN_ID = os.environ.get("AR_RUN_ID", "r0000")
AR_EXPR_DIR = Path(os.environ.get("AR_EXPR_DIR", str(Path(__file__).resolve().parent)))

# ======================================================================
# PARAMETER BLOCK — edit freely per run.
# ======================================================================

