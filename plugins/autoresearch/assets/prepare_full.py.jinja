# --------------------------- metric contract -----------------------------

primary_spec: dict[str, str] = {
    "name": "{{ primary_name }}",
    "direction": "{{ primary_direction }}",
}

aux_keys: list[str] = [
{% for k in auxiliary %}
    "{{ k }}",
{% endfor %}
]

hard_constraints: list[dict[str, Any]] = [
{% for c in hard_constraints %}
    {"name": "{{ c.name }}", "op": "{{ c.op }}", "threshold": {{ c.threshold }}},
{% endfor %}
]


def extract_metrics(wandb_summary: dict) -> dict[str, float]:
    out: dict[str, float] = {}
    wanted = [primary_spec["name"], *aux_keys, *(c["name"] for c in hard_constraints)]
    for key in wanted:
        if key in wandb_summary:
            try:
                out[key] = float(wandb_summary[key])
            except (TypeError, ValueError):
                continue
    return out


_LOG_LINE_RE = re.compile(
    r"^\s*([A-Za-z0-9_./-]+)\s*=\s*([-+]?(?:\d+\.?\d*|\.\d+)(?:[eE][-+]?\d+)?)\s*$",
    re.MULTILINE,
)


def extract_metrics_from_log(log_text: str) -> dict[str, float]:
    wanted = {primary_spec["name"], *aux_keys, *(c["name"] for c in hard_constraints)}
    found: dict[str, float] = {}
    for m in _LOG_LINE_RE.finditer(log_text):
        k, v = m.group(1), m.group(2)
        if k in wanted:
            try:
                found[k] = float(v)
            except ValueError:
                continue
    return found


def resume_ckpt_path() -> Path | None:
    expr_dir = Path(__file__).resolve().parent
    prog = expr_dir / "program.md"
    if not prog.is_file():
        return None
    try:
        text = prog.read_text(encoding="utf-8")
    except OSError:
        return None
    m = re.search(r"`parent_ckpt`\s*:\s*`([^`]+)`", text)
    if not m:
        return None
    p = Path(m.group(1)).expanduser()
    if not p.is_absolute():
        p = (expr_dir / p).resolve()
    state = p / "state.pt" if p.is_dir() else p
    return state if state.is_file() else None
